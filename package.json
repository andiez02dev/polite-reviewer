{
  "name": "polite-reviewer",
  "version": "1.0.0",
  "description": "GitHub App that uses an LLM (Gemini) to review pull requests via a background worker.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "dev:worker": "nodemon --exec tsx src/worker.ts",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-app",
    "pull-request",
    "ai",
    "openai",
    "bullmq"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
