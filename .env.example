PORT=3000

# GitHub App configuration
GITHUB_APP_ID=your_app_id_here
GITHUB_INSTALLATION_ID=optional_installation_id_here

# Option 1 (recommended for cloud): put PEM content directly in env var
# GITHUB_PRIVATE_KEY='-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----'

# Option 2 (local dev): load PEM from file path
GITHUB_PRIVATE_KEY_PATH=./keys/github-private-key.pem

# Webhook secret
WEBHOOK_SECRET=your_webhook_secret_here

# Redis
# For local development:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# For managed Redis (e.g. Railway), prefer a full URL with password:
# REDIS_URL=redis://default:password@host:6379

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

